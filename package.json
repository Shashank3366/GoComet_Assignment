{
  "name": "gocomet-fullstack",
  "version": "1.0.0",
  "description": "Full-stack RFQ System",
  "scripts": {
    "dev:backend": "nodemon backend/src/app.js",
    "dev:frontend": "vite frontend",
    "build:frontend": "vite build frontend",
    "build": "npm run build:frontend",
    "postinstall": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:push": "npx prisma db push --schema=backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "vite": "^8.0.10"
  }
}
